{
  "config": {
    "id": "booldev-senior-dotnet-interview-questions",
    "name": "bool.dev — Вопросы на собеседовании для Senior C# / .NET Developer",
    "auth": {
      "basic_user": "",
      "basic_password": "",
      "bearer_token": "",
      "cookie": ""
    },
    "scopes": {
      "allowed_domains": ["bool.dev"],
      "deny_url_patterns": [
        "/login",
        "/register",
        "/news",
        "/about",
        "/blog/tags/",
        "/blog/category/"
      ],
      "max_depth": 0
    },
    "seeds": [
      {
        "url": "https://bool.dev/blog/detail/voprosy-na-sobesedovanii-dlya-senior-net-developer"
      }
    ],
    "rate_limit": {
      "rps": 1,
      "max_concurrency": 2,
      "jitter_ms": 250
    },
    "retries": {
      "max_attempts": 3,
      "backoff_initial_ms": 500,
      "backoff_multiplier": 2
    },
    "schedule": {
      "cron": "0 9 * * 1"
    },
    "extraction_spec": {
      "fields": [
        {
          "name": "page_url",
          "type": "string",
          "required": true,
          "label": "Page URL",
          "extractor": {
            "source": "url",
            "selector_type": "const",
            "selector": "",
            "attribute": "",
            "multiple": false,
            "index": 0,
            "default_value": ""
          },
          "transforms": []
        },
        {
          "name": "title",
          "type": "string",
          "required": true,
          "label": "Title",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "h1[itemprop='headline']",
            "attribute": "text",
            "multiple": false,
            "index": 0,
            "default_value": ""
          },
          "transforms": []
        },
        {
          "name": "author",
          "type": "string",
          "required": false,
          "label": "Author",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "a[href^='/users/'] span[itemprop='name']",
            "attribute": "text",
            "multiple": false,
            "index": 0,
            "default_value": ""
          },
          "transforms": []
        },
        {
          "name": "publish_date",
          "type": "string",
          "required": false,
          "label": "Publish date (dd.mm.yyyy as shown)",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "span[itemprop='datePublished']",
            "attribute": "text",
            "multiple": false,
            "index": 0,
            "default_value": ""
          },
          "transforms": []
        },
        {
          "name": "publish_date_iso",
          "type": "string",
          "required": false,
          "label": "Publish date (ISO from content attr)",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "span[itemprop='datePublished']",
            "attribute": "content",
            "multiple": false,
            "index": 0,
            "default_value": ""
          },
          "transforms": []
        },
        {
          "name": "read_time",
          "type": "string",
          "required": false,
          "label": "Read time",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "span.mr-10 > i.far.fa-clock + span",
            "attribute": "text",
            "multiple": false,
            "index": 0,
            "default_value": ""
          },
          "transforms": []
        },

        {
          "name": "intro",
          "type": "json",
          "required": false,
          "label": "Intro paragraphs (first few <p> in article body)",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "div.blog-item.detail[itemprop~='articleBody'] p, div[itemprop~='articleBody'] p",
            "attribute": "text",
            "multiple": true,
            "default_value": "[]"
          },
          "transforms": [
            {
              "op": "limit",
              "arg": "3"
            }
          ]
        },
        {
          "name": "toc_sections_h2",
          "type": "json",
          "required": false,
          "label": "Section headings (H2)",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "div.blog-item.detail[itemprop~='articleBody'] h2, div[itemprop~='articleBody'] h2",
            "attribute": "text",
            "multiple": true,
            "default_value": "[]"
          },
          "transforms": []
        },
        {
          "name": "questions_h3",
          "type": "json",
          "required": false,
          "label": "Questions (H3)",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "div.blog-item.detail[itemprop~='articleBody'] h3, div[itemprop~='articleBody'] h3",
            "attribute": "text",
            "multiple": true,
            "default_value": "[]"
          },
          "transforms": []
        },
        {
          "name": "article_text",
          "type": "string",
          "required": false,
          "label": "Full article text (articleBody)",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "div.blog-item.detail[itemprop~='articleBody'], div[itemprop~='articleBody']",
            "attribute": "text",
            "multiple": false,
            "index": 0,
            "default_value": ""
          },
          "transforms": [
            {
              "op": "collapse_whitespace",
              "arg": ""
            }
          ]
        },
        {
          "name": "outbound_links",
          "type": "json",
          "required": false,
          "label": "Outbound links inside article body",
          "extractor": {
            "source": "html",
            "selector_type": "css",
            "selector": "div.blog-item.detail[itemprop~='articleBody'] a[href^='http']:not([href*='bool.dev']), div[itemprop~='articleBody'] a[href^='http']:not([href*='bool.dev'])",
            "attribute": "href",
            "multiple": true,
            "default_value": "[]"
          },
          "transforms": []
        }
      ],
      "metrics": [
        {
          "name": "questions_count",
          "op": "count",
          "input": "questions_h3",
          "arg": ""
        },
        {
          "name": "sections_count",
          "op": "count",
          "input": "toc_sections_h2",
          "arg": ""
        }
      ]
    }
  }
}

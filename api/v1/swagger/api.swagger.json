    "v1CrawlMode": {
      "type": "string",
      "enum": [
        "CRAWL_MODE_UNSPECIFIED",
        "CRAWL_MODE_PAGINATION_AND_LINKS",
        "CRAWL_MODE_PAGINATION_ONLY",
        "CRAWL_MODE_LINKS_ONLY"
      ],
      "default": "CRAWL_MODE_UNSPECIFIED",
      "description": "CrawlMode controls which link-following strategy the crawler uses.\n\n - CRAWL_MODE_UNSPECIFIED: Defaults to pagination_and_links\n - CRAWL_MODE_PAGINATION_AND_LINKS: Follow both pagination and regular links (default)\n - CRAWL_MODE_PAGINATION_ONLY: Follow only pagination links\n - CRAWL_MODE_LINKS_ONLY: Follow only regular \u003ca href\u003e links"
